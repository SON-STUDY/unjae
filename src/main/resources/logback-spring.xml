<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ===== LOCAL / DEFAULT: 사람이 읽기 쉬운 컬러 콘솔 ===== -->
    <springProfile name="local,default">

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%-5level] [trace=%X{traceId:-?}] [user=%X{userId:-?}] %logger{30} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <logger name="org.son.monitor" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.springframework.web.servlet.mvc.method.annotation.ExceptionHandlerExceptionResolver" level="OFF"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

    </springProfile>

    <!-- ===== PROD: JSON 구조화 로그 (Loki / ELK 수집용) ===== -->
    <springProfile name="prod">

        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- MDC 필드를 최상위 JSON 필드로 승격 -->
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <!-- 서비스 식별 고정 태그 -->
                <customFields>{"service":"monitor","env":"prod"}</customFields>
                <!-- 필드명 표준화 -->
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <message>message</message>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <level>level</level>
                </fieldNames>
                <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxDepthPerCause>10</maxDepthPerCause>
                    <shortenedClassNameLength>20</shortenedClassNameLength>
                    <rootCauseFirst>true</rootCauseFirst>
                </throwableConverter>
            </encoder>
        </appender>

        <logger name="org.son.monitor" level="INFO"/>
        <logger name="org.springframework.web.servlet.mvc.method.annotation.ExceptionHandlerExceptionResolver" level="OFF"/>

        <root level="WARN">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>

    </springProfile>

</configuration>
